---
import Layout from "../layouts/Layout.astro";
import NavigationBar from "../sections/1-navigation-bar.astro";

import { getLangFromUrl, useTranslations } from "../i18n/utils";

const t = useTranslations(getLangFromUrl(Astro.url));
---

<style scoped>
	body {
		margin: 0;
		overflow-x: hidden;
		background-color: #f8fafc;
	}
	.glass {
		background: rgba(251, 247, 252, 0.7);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid rgba(253, 248, 255, 0.5);
	}
	#canvas-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
	}
</style>
<Layout pageTitle="404 - Page Not Found">
	<NavigationBar />

	<div class="antialiased text-slate-800 min-h-screen flex flex-col relative">
		<canvas id="canvas-container"></canvas>

		<main
			class="flex-grow flex items-center justify-center px-4 sm:px-6 lg:px-8 pt-20"
		>
			<div class="max-w-3xl w-full text-center space-y-8 relative z-10">
				<div class="relative inline-block animate-float">
					<h1
						class="font-display text-[8rem] sm:text-[12rem] font-extrabold leading-none tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-primary-800 via-primary-600 to-pink-700 drop-shadow-sm font-mono"
					>
						404
					</h1>

					<div
						class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-primary-500/10 blur-3xl rounded-full -z-10 animate-pulse-slow"
					>
					</div>
				</div>

				<div class="space-y-4">
					<h2
						class="text-3xl sm:text-4xl font-display font-bold text-slate-900"
					>
						Oops! This page isn't on the syllabus.
					</h2>
					<p
						class="text-lg sm:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed"
					>
						{t("notfound_discription")}
					</p>
				</div>

				<div
					class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-6"
				>
					<a
						href="/"
						class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-primary-700 to-primary-600 hover:from-primary-800 hover:to-primary-700 text-white rounded-xl font-semibold transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-1 flex items-center justify-center gap-2"
					>
						<i class="fa-solid fa-house"></i>
						Back to Home
					</a>
					<a
						href="/past-papers"
						class="w-full sm:w-auto px-8 py-4 bg-white border-2 border-slate-200 hover:border-primary-500 text-slate-700 hover:text-primary-700 rounded-xl font-semibold transition-all duration-200 shadow-sm hover:shadow-md flex items-center justify-center gap-2 group"
					>
						<i
							class="fa-solid fa-file-lines text-slate-400 group-hover:text-primary-500 transition-colors"
						></i>
						View Past Papers
					</a>
				</div>

				<!-- Additional Help Links -->
				<div class="pt-12 border-t border-slate-200 mt-12">
					<p class="text-sm text-slate-500 mb-4">
						Looking for something specific?
					</p>
					<div class="flex flex-wrap justify-center gap-6 text-sm font-medium">
						<a
							href="/practicepapers"
							class="text-primary-600 hover:text-primary-800 hover:underline transition-colors"
							>Practice Papers</a
						>
						<a
							href="/results"
							class="text-primary-600 hover:text-primary-800 hover:underline transition-colors"
							>Exam Results</a
						>
						<a
							href="/feedback"
							class="text-primary-600 hover:text-primary-800 hover:underline transition-colors"
							>Contact Committee</a
						>
					</div>
				</div>
			</div>
		</main>

		<footer
			class="w-full py-6 text-center text-slate-500 text-sm mt-auto glass"
		>
			<p>
				Made with <i class="fa-solid fa-heart text-purple-500 mx-1"></i> by Mora
				Exams.
			</p>
		</footer>
	</div>
</Layout>

<script>
	const canvas = document.getElementById(
		"canvas-container",
	) as HTMLCanvasElement;
	const ctx = canvas.getContext("2d")!;

	let particlesArray: Particle[] = [];

	// Symbols representing A/L Streams and Engineering (Mora Exams theme)
	// Math, Physics, Chem, Bio, ICT, Engineering
	const symbols = [
		"∑",
		"∫",
		"π",
		"Ω",
		"∞",
		"H₂O",
		"⚡",
		"💻",
		"🧬",
		"⚙️",
		"∆",
		"θ",
		"µ",
		"√",
		"∂",
		"λ",
	] as const;

	// Function to resize canvas to full window size
	function resizeCanvas() {
		canvas.width = window.innerWidth;
		canvas.height = window.innerHeight;
	}

	window.addEventListener("resize", resizeCanvas);
	resizeCanvas();

	// Particle Class
	class Particle {
		x: number;
		y: number;
		size: number;
		speedX: number;
		speedY: number;
		symbol: string; // or typeof symbols[number] if you want to be extra strict
		opacity: number;
		color: string;
		constructor() {
			this.x = Math.random() * canvas.width;
			this.y = Math.random() * canvas.height;
			this.size = Math.random() * 15 + 10;
			this.speedX = Math.random() * 0.5 - 0.25;
			this.speedY = Math.random() * 0.5 - 0.25;
			this.symbol = symbols[Math.floor(Math.random() * symbols.length)];
			this.opacity = Math.random() * 0.15 + 0.05;

			// Assign a color theme (Violets and slate)
			const colors = ["#8b5cf6", "#7c3aed", "#64748b", "#94a3b8"] as const;
			this.color = colors[Math.floor(Math.random() * colors.length)];
		}

		update() {
			this.x += this.speedX;
			this.y += this.speedY;

			// Wrap around edges
			if (this.x > canvas.width + 50) this.x = -50;
			if (this.x < -50) this.x = canvas.width + 50;
			if (this.y > canvas.height + 50) this.y = -50;
			if (this.y < -50) this.y = canvas.height + 50;
		}

		draw() {
			ctx.font = `${this.size}px 'Inter', sans-serif`;
			ctx.fillStyle = this.color;
			ctx.globalAlpha = this.opacity;
			ctx.fillText(this.symbol, this.x, this.y);
			ctx.globalAlpha = 1.0; // reset alpha
		}
	}

	// Initialize particles
	function init() {
		particlesArray = [];
		// Amount of particles scales based on screen width to avoid clutter on mobile
		let numberOfParticles = (canvas.width * canvas.height) / 15000;

		// Cap the maximum particles
		if (numberOfParticles > 100) numberOfParticles = 100;

		for (let i = 0; i < numberOfParticles; i++) {
			particlesArray.push(new Particle());
		}
	}

	// Animation Loop
	function animate() {
		ctx.clearRect(0, 0, canvas.width, canvas.height);
		for (let i = 0; i < particlesArray.length; i++) {
			particlesArray[i].update();
			particlesArray[i].draw();
		}
		requestAnimationFrame(animate);
	}

	// Ensure animation starts only after window is fully loaded
	window.onload = () => {
		init();
		animate();
	};

	// Re-initialize on resize to ensure good distribution
	window.addEventListener("resize", () => {
		init();
	});
</script>
